{
  "name": "hoc-cung-bee",
  "private": true,
  "scripts": {
    "mobile": "npm run start:dev --prefix apps/mobile",
    "mobile:dev": "npm run start:dev --prefix apps/mobile",
    "mobile:prod": "npm run start:prod --prefix apps/mobile",
    "mobile:typecheck": "npm run typecheck --prefix apps/mobile",
    "mobile:build:web": "npm run build:web --prefix apps/mobile",
    "install:mobile": "npm install --prefix apps/mobile",
    "mobile:build:apk": "npm run build:apk --prefix apps/mobile",
    "db:push": "npx supabase db push",
    "db:push:api": "node scripts/db-push-api.js",
    "db:sync": "node scripts/compose-apply-all.js && node scripts/db-sync.js",
    "db:sync:force": "node scripts/compose-apply-all.js && node scripts/db-sync.js --force",
    "db:compose": "node scripts/compose-apply-all.js",
    "vocab:gen": "node scripts/gen-daily-vocab-ts.js",
    "db:reset:local": "npx supabase db reset",
    "db:start": "npx supabase start",
    "test:bdd": "npm run test --prefix tests",
    "test:bdd:fn17": "npm run test:fn17 --prefix tests",
    "test:bdd:fn01": "npm run test:fn01 --prefix tests",
    "test:bdd:fn02": "npm run test:fn02 --prefix tests",
    "test:bdd:ui": "npm run mobile:build:web && npm run test:ui --prefix tests",
    "test:bdd:fn01:ui": "npm run mobile:build:web && npm run test:fn01:ui --prefix tests",
    "test:perf": "npm run test:perf --prefix tests",
    "test:bdd:perf": "npm run test:perf:bdd --prefix tests"
  },
  "devDependencies": {
    "pg": "^8.21.0",
    "supabase": "^2.101.0"
  }
}
