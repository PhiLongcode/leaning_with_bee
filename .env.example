# Root — tham chiếu; Expo đọc env tại apps/mobile/
# Xem apps/mobile/ENVIRONMENT.md

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=Học cùng Bee (Dev)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-publishable-key

# Đồng bộ DB tự động (npm run db:sync / khi chạy mobile:dev)
# Cách 1 — Supabase CLI / Management API:
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your_project_ref

# Cách 2 — Postgres (Dashboard → Settings → Database → Reset password nếu 28P01):
# SUPABASE_DB_PASSWORD=your_database_password
# SUPABASE_DB_REGION=ap-southeast-1
# SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
# Hoặc DATABASE_URL — copy nguyên Session pooler từ Dashboard → Connect

# --- AI (task FN-07, FN-17 — KHÔNG đưa vào EXPO_PUBLIC_*) ---
# Gateway Anthropic / router nội bộ (Claude Code, script local):
# ANTHROPIC_BASE_URL=https://your-ai-gateway.example
# ANTHROPIC_API_KEY=sk-your-key
# ANTHROPIC_DEFAULT_SONNET_MODEL=kr/claude-sonnet-4.6-agentic
# ANTHROPIC_DEFAULT_OPUS_MODEL=kr/claude-opus-4.6[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=cx/gpt-5.4
# ANTHROPIC_CUSTOM_MODEL_OPTION=cx/gpt-5.5-xhigh
# CLAUDE_CODE_SUBAGENT_MODEL=cx/gpt-5.3-codex

# Supabase Edge (OpenAI-compatible /v1/chat/completions):
# OPENAI_API_KEY=sk-your-key
# OPENAI_BASE_URL=https://your-ai-gateway.example/v1
# OPENAI_MODEL=kr/claude-sonnet-4.6-agentic
# AI_DEFAULT_MODEL=kr/claude-sonnet-4.6-agentic
#
# Đẩy secret lên Supabase:
# npx supabase secrets set OPENAI_API_KEY=... OPENAI_BASE_URL=... OPENAI_MODEL=...

# Integration API tests (Vitest tests/integration/) — ưu tiên TEST_* riêng
# TEST_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
# TEST_SUPABASE_ACCESS_TOKEN=eyJ...  # tùy chọn — bỏ qua signInAnonymously khi bị rate limit
# TEST_SUPABASE_REFRESH_TOKEN=
# TEST_SUPABASE_ANON_KEY=your-dev-anon-key
# TEST_DEVICE_ID=test-device-api-001

# Performance smoke (FN-17) — map từ EXPO_PUBLIC_* nếu không set
# PERF_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# PERF_SUPABASE_ANON_KEY=your-anon-key
# PERF_P95_MS=30000
# PERF_VUS=2
# PERF_DURATION=30s
